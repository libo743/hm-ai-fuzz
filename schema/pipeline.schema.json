{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hm-ai-fuzz.local/schema/pipeline.schema.json",
  "title": "hm-ai-fuzz Full Pipeline Output",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "discover_v2",
    "discover_llm_v2",
    "discover_merged_v2",
    "diff_v2",
    "generate_v2",
    "validate_v2"
  ],
  "properties": {
    "discover": {
      "type": "array"
    },
    "discover_llm": {
      "type": "array"
    },
    "discover_merged": {
      "type": "array"
    },
    "diff": {
      "type": "object"
    },
    "generate": {
      "type": "object"
    },
    "validate": {
      "type": "object"
    },
    "publish": {
      "type": "object"
    },
    "llm_discover_suggestions": {
      "type": "object"
    },
    "llm_model_suggestions": {
      "type": "object"
    },
    "llm_fix_suggestions": {
      "type": "object"
    },
    "discover_v2": {
      "$ref": "./discover.schema.json"
    },
    "discover_llm_v2": {
      "$ref": "./discover.schema.json"
    },
    "discover_merged_v2": {
      "$ref": "./discover.schema.json"
    },
    "diff_v2": {
      "$ref": "./diff.schema.json"
    },
    "generate_v2": {
      "$ref": "./generate.schema.json"
    },
    "validate_v2": {
      "$ref": "./validate.schema.json"
    }
  }
}
