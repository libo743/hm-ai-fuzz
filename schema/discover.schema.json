{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hm-ai-fuzz.local/schema/discover.schema.json",
  "title": "hm-ai-fuzz Discover Output",
  "description": "Shared schema for base discover, llm discover, and merged discover v2 outputs.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "subsystem",
    "source_root",
    "scope",
    "items",
    "summary"
  ],
  "properties": {
    "schema_version": {
      "$ref": "./common.schema.json#/$defs/schemaVersion"
    },
    "subsystem": {
      "$ref": "./common.schema.json#/$defs/subsystemName"
    },
    "source_root": {
      "type": "string",
      "minLength": 1
    },
    "scope": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "target_subsystem"
      ],
      "properties": {
        "target_subsystem": {
          "type": "string",
          "minLength": 1
        },
        "scope_path": {
          "type": [
            "string",
            "null"
          ]
        },
        "scope_strategy": {
          "type": "string",
          "enum": [
            "path_first",
            "semantic_first",
            "hybrid"
          ]
        },
        "semantic_signals": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "search_method": {
          "type": "string"
        },
        "scan_mode": {
          "type": "string"
        }
      }
    },
    "items": {
      "type": "array",
      "items": {
        "$ref": "./common.schema.json#/$defs/interfaceItem"
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "item_count"
      ],
      "properties": {
        "item_count": {
          "type": "integer",
          "minimum": 0
        },
        "operation_count": {
          "type": "integer",
          "minimum": 0
        },
        "warning_count": {
          "type": "integer",
          "minimum": 0
        },
        "source_mode": {
          "type": "string",
          "enum": [
            "base",
            "llm",
            "merged"
          ]
        }
      }
    }
  }
}
